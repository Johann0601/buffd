# Eingebaute Standard-API-Keys (optional). Kopiere diese Datei nach .env und
# trage Keys ein — sie werden beim Build (npm run dist/release) eingebacken,
# sodass Nutzer der App KEINEN eigenen Key brauchen.
#
# .env ist gitignored und landet NICHT im Repo. Ein eingebauter Key ist aus
# der fertigen App extrahierbar — daher nur kostenlose, neu generierbare
# App-Keys verwenden (SteamGridDB, IsThereAnyDeal). Den persönlichen
# Steam-Web-API-Key bewusst NICHT einbauen.

# SteamGridDB (bessere Cover): steamgriddb.com -> Profil -> Preferences -> API
MAIN_VITE_SGDB_KEY=

# IsThereAnyDeal (Bestpreise + Tiefstpreis): isthereanydeal.com -> App registrieren
MAIN_VITE_ITAD_KEY=
